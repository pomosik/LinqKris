namespace Linq;

public class Linq
{
    public static void Main(string[] args)
    {

        List<string> list = new List<string>();

        while (true)
        {

            string input = Console.ReadLine()!;

            if (input == "exit")
            {
                break;
            }

            list.Add(input);

        }

        foreach (string word in list) { Console.WriteLine(word); }
    }
}
